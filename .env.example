# Copy to .env.local and fill in. .env.local is git-ignored.
# No user/admin password, hash, or OTP ever lives here — those are in the DB.

MONGODB_URI=
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

IMAGEKIT_PUBLIC_KEY=
IMAGEKIT_PRIVATE_KEY=
IMAGEKIT_URL_ENDPOINT=

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# SMS for OTP. Empty SMS_PROVIDER = dev console OTP fallback.
SMS_PROVIDER=
SMS_API_KEY=
SMS_SENDER_ID=

WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
RESEND_API_KEY=

# Used ONCE by scripts/seed-admin.ts to bootstrap the owner, then remove.
SEED_OWNER_EMAIL=
SEED_OWNER_PASSWORD=

NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_META_PIXEL_ID=
